# Copy to .env.local and fill in. Do not commit .env.local.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- football-data.org ---
FOOTBALL_DATA_TOKEN=

# --- pg_cron ---
# Shared secret between pg_cron jobs and /api/cron/* route handlers.
# Must match the Postgres GUC `app.cron_secret` (see supabase/migrations/0003_cron.sql).
CRON_SECRET=

# --- Sentry (optional) ---
# When unset, all Sentry integration no-ops (no events sent, no source-map upload).
# Sign up at sentry.io (EU region), create a Next.js project, copy the DSN here.
NEXT_PUBLIC_SENTRY_DSN=

# Set in Vercel only — used at build time for source-map upload + release tagging.
# Create an Internal Integration auth token with `project:releases` + `org:read` scopes.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Dev only ---
# When set to "1", /login bypasses the magic-link flow and signs in instantly.
# Never set in production.
DEV_INSTANT_LOGIN=
